NODE_ENV=development
HOST=127.0.0.1
PORT=3010
PUBLIC_BASE_URL=https://celticspear.com
MCP_PATH=/mcp
# Optional no-auth MCP path for ChatGPT Web developer-mode testing.
# Use a long random path and keep it private.
CHATGPT_MCP_PATH=
REST_BASE_PATH=/tg-mcp/api
OPENAPI_PATH=/tg-mcp/openapi.json
ALLOWED_HOSTS=127.0.0.1,localhost,celticspear.com,www.celticspear.com

MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=tg_mcp
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

TELEGRAM_MODE=user
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_FILE=/srv/tg-mcp/shared/sessions/telegram.session
TELEGRAM_SYNC_LIMIT=200
TELEGRAM_SYNC_ENABLED=false
TELEGRAM_SYNC_INTERVAL_SECONDS=300
TELEGRAM_SYNC_ON_START=true

# Optional OpenAI Audio Transcriptions pipeline for Telegram voice/audio messages.
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_ENABLED=false
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_RESPONSE_FORMAT=json
OPENAI_TRANSCRIPTION_PROMPT=
OPENAI_TRANSCRIPTION_LANGUAGE=
# Optional: "auto" or a JSON server_vad object for models that support chunking_strategy.
OPENAI_TRANSCRIPTION_CHUNKING_STRATEGY=
# Comma-separated Telegram source ids/tags where audio transcription is allowed.
AUDIO_TRANSCRIPTION_SOURCE_IDS=
AUDIO_TRANSCRIPTION_SOURCE_TAGS=
AUDIO_TRANSCRIPTION_INTERVAL_SECONDS=3600
AUDIO_TRANSCRIPTION_ON_START=true
AUDIO_TRANSCRIPTION_BATCH_SIZE=1
AUDIO_TRANSCRIPTION_LOCK_MS=600000
AUDIO_TRANSCRIPTION_MAX_ATTEMPTS=3
AUDIO_TRANSCRIPTION_WORK_DIR=/srv/tg-mcp/shared/audio-work
AUDIO_TRANSCRIPTION_MAX_FILE_BYTES=26214400
AUDIO_TRANSCRIPTION_SPLIT_LARGE_FILES=true
FFMPEG_PATH=ffmpeg

# Optional read-only Telegram bot with slash commands:
# /digest_today, /digest_week, /search, /actions, /sources
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ALLOWED_CHAT_IDS=
TELEGRAM_BOT_TIMEZONE=Europe/Chisinau

# Comma-separated Telegram source ids. Only these chats/channels are enabled.
ALLOWED_SOURCE_IDS=

# Optional quick personal auth. If set, MCP/admin calls require:
# Authorization: Bearer <APP_AUTH_TOKEN>
APP_AUTH_TOKEN=

# Production refuses to start without APP_AUTH_TOKEN unless this is explicitly true.
ALLOW_UNAUTHENTICATED=false
